# Gotenberg Gateway Environment Configuration
# This file is the single source of truth for configurable ports and settings.
# Both docker-compose and start.sh will read from this.

# Ports
GATEWAY_PORT=9225
GOTENBERG_PORT=9125

# Concurrency limits for the Gateway
GATEWAY_MAX_CONCURRENT=10
GATEWAY_MAX_QUEUE=50

# Application Log Level
GATEWAY_LOG_LEVEL=INFO
